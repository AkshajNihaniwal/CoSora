# Database
DATABASE_URL="postgresql://cosora:cosora@localhost:5432/cosora"
REDIS_URL="redis://localhost:6379"

# Auth
JWT_SECRET="your-jwt-secret-min-32-chars-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-min-32-chars-change-in-production"

# Azure OpenAI (optional fallback)
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_KEY=""
AZURE_OPENAI_DEPLOYMENT="gpt-4o"

# GitHub Models API (primary LLM — set token to enable live AI)
GITHUB_MODELS_TOKEN=""
GITHUB_MODELS_MODEL="openai/gpt-4o"
GITHUB_MODELS_ENDPOINT="https://models.github.ai/inference/chat/completions"
AZURE_BING_SEARCH_KEY=""
AZURE_BING_SEARCH_ENDPOINT="https://api.bing.microsoft.com/v7.0/search"

# Email (use Ethereal for dev: https://ethereal.email)
SMTP_HOST="smtp.ethereal.email"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="cosora@yourdomain.com"
INTERNAL_EMAIL_DOMAIN="yourdomain.com"

# Storage
STORAGE_PROVIDER="local"
UPLOAD_DIR="./uploads"
MAX_UPLOAD_FILE_SIZE_MB=500
MAX_UPLOAD_FILES=10
MAX_EXTRACT_CHARS=150000

# Azure Blob (production)
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_STORAGE_CONTAINER="cosora-documents"

# App
PORT=4000
FRONTEND_URL="http://localhost:3000"
NODE_ENV="development"

# CLM integrations (optional)
IRONCLAD_API_KEY=""
DOCUSIGN_API_KEY=""
